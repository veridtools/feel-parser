{
  "name": "@veridtools/feel-parser",
  "version": "0.1.1",
  "description": "FEEL expression lexer and parser — produces a typed AST from FEEL source",
  "author": "Victor Martins Bicudo",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "homepage": "https://github.com/veridtools/feel-parser#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/veridtools/feel-parser.git"
  },
  "bugs": {
    "url": "https://github.com/veridtools/feel-parser/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "feel-parser": "./dist/bin/feel-parser.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "dmn",
    "feel",
    "feel-expression",
    "feel-parser",
    "ast",
    "dmn-1.5",
    "veridtools",
    "omg",
    "typescript"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "changeset": "changeset",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@changesets/cli": "^2.27.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@types/node": "^20.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "tsup": "^8",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitepress": "^1.6.4",
    "vitest": "^2"
  }
}
